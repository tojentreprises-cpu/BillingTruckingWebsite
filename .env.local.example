# ============================================================
# Contact form configuration (all values are PUBLIC / safe to expose)
# Copy this file to `.env.local` and fill in your keys.
# `.env.local` is gitignored — never commit real values there anyway.
# ============================================================

# 1) Web3Forms Access Key — REQUIRED for the form to send.
#    Sign up free at https://web3forms.com using billingtrucking@yahoo.com,
#    then paste the Access Key it emails you here.
#    This is a submit-only token: it can ONLY deliver to your inbox.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# 2) Cloudflare Turnstile Site Key — OPTIONAL but recommended (bot protection).
#    Create a free widget at https://dash.cloudflare.com/?to=/:account/turnstile
#    Put the SITE key here, and paste the SECRET key into your Web3Forms
#    dashboard (Settings → Spam protection → Cloudflare Turnstile).
#    The secret key must NEVER go in this file or any client code.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
